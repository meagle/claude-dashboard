{
  "name": "@claude-dashboard/tui",
  "version": "0.1.0",
  "bin": { "claude-dashboard": "dist/index.js" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.tsx",
    "test": "jest"
  },
  "dependencies": {
    "@claude-dashboard/shared": "*",
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "tsx": "^4.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ink-testing-library": "^3.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleDirectories": ["node_modules", "../../node_modules"],
    "testPathIgnorePatterns": ["/node_modules/", "/dist/", "\\.d\\.ts$"],
    "moduleNameMapper": {
      "^@claude-dashboard/shared$": "<rootDir>/../shared/src/index.ts",
      "^ink-testing-library$": "<rootDir>/src/__mocks__/ink-testing-library.ts",
      "^ink$": "<rootDir>/src/__mocks__/ink.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
    }
  }
}
