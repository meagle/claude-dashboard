{
  "name": "@claude-dashboard/menubar",
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.main.json && vite build",
    "dev": "concurrently --kill-others -n tsc,vite,electron \"tsc -w --project tsconfig.main.json\" \"vite dev\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@claude-dashboard/shared": "*",
    "@tailwindcss/vite": "^4.2.2",
    "chokidar": "^3.6.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^30.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.4.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
