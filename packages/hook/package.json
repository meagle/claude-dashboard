{
  "name": "@claude-dashboard/hook",
  "version": "0.1.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/hook.ts",
    "test": "jest"
  },
  "dependencies": {
    "@claude-dashboard/shared": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    },
    "moduleNameMapper": {
      "^@claude-dashboard/shared$": "<rootDir>/../shared/src/index.ts"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/dist/"
    ]
  }
}
